{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "quran-tasmee3",
  "compatibility_date": "2026-02-09",
  "pages_build_output_dir": "./dist",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "quran-tasmee3-production",
      "database_id": "placeholder-will-be-set-on-deploy"
    }
  ]
}
