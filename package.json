{
  "name": "quran-tasmee3",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "wrangler pages dev dist",
    "deploy": "npm run build && wrangler pages deploy dist --project-name quran-tasmee3",
    "dev:sandbox": "wrangler pages dev dist --d1=quran-tasmee3-production --local --ip 0.0.0.0 --port 3000",
    "db:migrate:local": "wrangler d1 migrations apply quran-tasmee3-production --local",
    "db:migrate:prod": "wrangler d1 migrations apply quran-tasmee3-production",
    "db:reset": "rm -rf .wrangler/state/v3/d1 && npm run db:migrate:local",
    "clean-port": "fuser -k 3000/tcp 2>/dev/null || true"
  },
  "dependencies": {
    "hono": "^4.11.9"
  },
  "devDependencies": {
    "@hono/vite-build": "^1.2.0",
    "@hono/vite-dev-server": "^0.18.2",
    "vite": "^6.3.5",
    "wrangler": "^4.4.0"
  }
}
